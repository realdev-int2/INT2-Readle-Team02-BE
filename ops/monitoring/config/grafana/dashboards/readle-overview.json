{
  "uid": "readle-overview",
  "title": "Readle Overview",
  "schemaVersion": 39,
  "version": 7,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Backend Up",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "up{job=\"backend\"}", "instant": true}]
    },
    {
      "type": "stat",
      "title": "MySQL Up",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "up{job=\"mysql\"}"}]
    },
    {
      "type": "stat",
      "title": "Host CPU Usage",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1}, "overrides": []},
      "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"node\",mode=\"idle\"}[5m])) * 100)"}]
    },
    {
      "type": "stat",
      "title": "Root Disk Usage",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1}, "overrides": []},
      "targets": [{"expr": "100 * (1 - (node_filesystem_avail_bytes{job=\"node\",mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{job=\"node\",mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}))"}]
    },
    {
      "type": "timeseries",
      "title": "Host Memory Available",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "targets": [{"expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available"}]
    },
    {
      "type": "timeseries",
      "title": "Container Memory",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "targets": [{"expr": "sum by (name) (podman_container_mem_usage_bytes * on(id, instance, job) group_left(name) podman_container_info)", "legendFormat": "{{name}}"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests / 5xx",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "targets": [
        {"expr": "sum(rate(http_server_requests_seconds_count{job=\"backend\",uri!~\"/api/actuator/.*\"}[5m]))", "legendFormat": "requests/s"},
        {"expr": "sum(rate(http_server_requests_seconds_count{job=\"backend\",status=~\"5..\",uri!~\"/api/actuator/.*\"}[5m]))", "legendFormat": "5xx/s"}
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Used",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "targets": [{"expr": "sum(jvm_memory_used_bytes{job=\"backend\",area=\"heap\"})", "legendFormat": "Heap Used"}]
    },
    {
      "type": "timeseries",
      "title": "DB Connection Pool Usage",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []},
      "targets": [{"expr": "100 * sum(hikaricp_connections_active{job=\"backend\"}) / clamp_min(sum(hikaricp_connections_max{job=\"backend\"}), 1)", "legendFormat": "Pool Usage"}]
    }
  ]
}
